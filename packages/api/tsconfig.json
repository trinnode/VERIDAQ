{
  "compilerOptions": {
    "target":         "ES2022",
    "module":         "Node16",
    "moduleResolution": "Node16",
    "lib":            ["ES2022"],
    "outDir":         "./dist",
    "rootDir":        "./src",
    "strict":         true,
    "esModuleInterop": true,
    "skipLibCheck":   true,
    "resolveJsonModule": true,
    "declaration":    true,
    "declarationMap": true,
    "sourceMap":      true,
    /* fail loudly on any implicit `any` */
    "noImplicitAny":  true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
